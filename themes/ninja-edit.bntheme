{
    "name": "Ninja Edit",
    "style": "Fusion",
    "styleSheet": [
        "QMenu { background-color: #2e3132; border: 1px solid #4e5354; }",
        "QMenu::separator { background-color: palette(window); height: 1px; }",
        "QMenu::item:selected { background-color: palette(highlight); }",
        "QMenu::item:disabled { color: #969089; }",
        "QPushButton:disabled { color: palette(light); }",
        "QComboBox:disabled { color: palette(light); }",
        "QLabel:disabled { color: palette(light); }"
    ],

    "colors": {
        "red":            [241, 123, 113],
        "orange":         [244, 188, 129],
        "yellow":         [241, 230, 114],
        "green":          [129, 238, 158],
        "cyan":           [123, 230, 222],
        "sky":            [129, 209, 241],
        "blue":           [164, 183, 241],
        "mauve":          [222, 164, 241],
        "pink":           [236, 162, 209],
        "night":          [15, 17, 17],
        "black":          [26, 28, 28],
        "gunmetal":       [36, 38, 39],
        "jet":            [46, 49, 50],
        "onyx":           [56, 60, 61],
        "charcoal":       [67, 71, 72],
        "slate":          [78, 83, 84],
        "gray":           [102, 108, 109],
        "silver":         [150, 144, 137],
        "platinum":       [191, 183, 175],
        "white":          [230, 226, 222],
        "shadow":         [0, 0, 0, 128],
        "highlight":      [255, 255, 255, 128],
        "invisible":      [0, 0, 0, 0],
        "outline":        [196, 196, 196, 98],
        "tokenHighlight": [211, 108, 99, 224]
    },

    "palette": {
        "Window":          "onyx",
        "WindowText":      "white",
        "Base":            "night",
        "AlternateBase":   "gunmetal",
        "ToolTipBase":     "charcoal",
        "ToolTipText":     "white",
        "Text":            "white",
        "Button":          "charcoal",
        "ButtonText":      "white",
        "BrightText":      "yellow",
        "Link":            "sky",
        "LinkVisited":     "mauve",
        "Highlight":       "sky",
        "HighlightedText": "night",
        "Light":           "platinum",
        "PlaceholderText": "platinum"
    },

    "disabledPalette": {
        "Button":      "slate",
        "WindowText":  "platinum",
        "ToolTipText": "platinum",
        "Text":        "platinum",
        "ButtonText":  "platinum"
    },

    "theme-colors": {
        "addressColor":    "green",
        "modifiedColor":   "red",
        "insertedColor":   "blue",
        "notPresentColor": "platinum",
        "selectionColor":  "gray",
        "outlineColor":    "platinum",

        "backgroundHighlightDarkColor":      "night",
        "backgroundHighlightLightColor":     "onyx",
        "boldBackgroundHighlightDarkColor":  "night",
        "boldBackgroundHighlightLightColor": "gray",
        "alphanumericHighlightColor":        "blue",
        "printableHighlightColor":           "cyan",

        "graphBackgroundDarkColor":            "black",
        "graphBackgroundLightColor":           "black",
        "graphNodeDarkColor":                  "jet",
        "graphNodeLightColor":                 "jet",
        "graphNodeOutlineColor":               "outline",
        "graphNodeShadowColor":                "shadow",
        "graphEntryNodeIndicatorColor":        "green",
        "graphExitNodeIndicatorColor":         "platinum",
        "graphExitNoreturnNodeIndicatorColor": "red",

        "trueBranchColor":             "green",
        "falseBranchColor":            "red",
        "unconditionalBranchColor":    "blue",
        "altTrueBranchColor":          "blue",
        "altFalseBranchColor":         "orange",
        "altUnconditionalBranchColor": "platinum",

        "instructionColor":                 ["+", "yellow", "white"],
        "registerColor":                    "white",
        "numberColor":                      "green",
        "codeSymbolColor":                  "blue",
        "dataSymbolColor":                  "sky",
        "stackVariableColor":               "cyan",
        "localVariableColor":               "white",
        "importColor":                      "orange",
        "exportColor":                      "pink",
        "instructionHighlightColor":        [143, 151, 153],
        "relatedInstructionHighlightColor": "gray",
        "tokenHighlightColor":              "tokenHighlight",
        "tokenSelectionColor":              "charcoal",
        "annotationColor":                  "silver",
        "commentColor":                     "silver",
        "operationColor":                   [167, 192, 199],
        "opcodeColor":                      "silver",
        "stringColor":                      "pink",
        "typeNameColor":                    "orange",
        "fieldNameColor":                   "cyan",
        "keywordColor":                     "yellow",
        "uncertainColor":                   "silver",
        "nameSpaceColor":                   "blue",
        "nameSpaceSeparatorColor":          "blue",
        "gotoLabelColor":                   "blue",
        "baseStructureNameColor":           "pink",

        "linearDisassemblyFunctionHeaderColor": "charcoal",
        "linearDisassemblyBlockColor":          "gunmetal",
        "linearDisassemblyNoteColor":           "jet",
        "linearDisassemblySeparatorColor":      "outline",
        "linearDisassemblyCodeFoldColor":       "white",
        "indentationLineColor":                 ["~", "outline", "gunmetal", 127],
        "indentationLineHighlightColor":        "platinum",

        "scriptConsoleOutputColor":  "white",
        "scriptConsoleWarningColor": "yellow",
        "scriptConsoleErrorColor":   "red",
        "scriptConsoleEchoColor":    "platinum",

        "blueStandardHighlightColor":    "blue",
        "greenStandardHighlightColor":   "green",
        "cyanStandardHighlightColor":    "cyan",
        "redStandardHighlightColor":     "red",
        "magentaStandardHighlightColor": "pink",
        "yellowStandardHighlightColor":  "yellow",
        "orangeStandardHighlightColor":  "orange",
        "whiteStandardHighlightColor":   "white",
        "blackStandardHighlightColor":   "black",

        "miniGraphOverlayColor": "white",

        "sidebarBackgroundColor":          "onyx",
        "sidebarInactiveIconColor":        "white",
        "sidebarHoverIconColor":           "white",
        "sidebarActiveIconColor":          "white",
        "sidebarFocusedIconColor":         "night",
        "sidebarHoverBackgroundColor":     ["~", "onyx", "gray", 128],
        "sidebarActiveBackgroundColor":    "gray",
        "sidebarFocusedBackgroundColor":   "sky",
        "sidebarActiveIndicatorLineColor": "invisible",
        "sidebarHeaderBackgroundColor":    "onyx",
        "sidebarHeaderTextColor":          "white",
        "sidebarWidgetBackgroundColor":    "gunmetal",

        "focusedPaneBackgroundColor": [83, 90, 106],

        "structureTypeColor":      "blue",
        "enumerationTypeColor":    "green",
        "voidTypeColor":           "red",
        "functionTypeColor":       "red",
        "boolTypeColor":           "red",
        "integerTypeColor":        "red",
        "floatTypeColor":          "red",
        "pointerTypeColor":        "red",
        "arrayTypeColor":          "red",
        "varArgsTypeColor":        "red",
        "valueTypeColor":          "red",
        "namedTypeReferenceColor": "red",
        "wideCharTypeColor":       "red"
    }
}
